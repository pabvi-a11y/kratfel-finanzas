# KRATFEL Finanzas — variables de entorno (NO subir el .env real al repo)
# Copia este archivo a .env y rellena los valores en el servidor (SiteGround).

# --- Base de datos (SiteGround MySQL) ---
DB_HOST=localhost
DB_NAME=kratfel_finanzas
DB_USER=
DB_PASS=

# --- Clave de cifrado (tokens QBO en reposo). Genera una con:
#     php -r "echo base64_encode(random_bytes(32));"
APP_ENCRYPTION_KEY=

# --- QuickBooks Online / Intuit ---
# 'sandbox' para pruebas con la empresa de prueba, 'production' para Naval Solutions
QBO_ENV=sandbox
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=https://finanzas.usuarioseri2y3.com/qbo/callback.php
# Realm/Company ID (se rellena solo tras el primer consent, pero puedes fijarlo)
QBO_REALM_ID=

# --- App ---
APP_BASE_URL=https://finanzas.usuarioseri2y3.com
APP_TIMEZONE=America/Chicago
SUPPORT_EMAIL=admin@usuarioseri2y3.com
